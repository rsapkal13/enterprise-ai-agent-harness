{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Price Delta Output",
  "type": "object",
  "required": ["currency", "monthly_delta", "summary"],
  "properties": {
    "currency": {
      "type": "string",
      "description": "Fictional currency code."
    },
    "monthly_delta": {
      "type": "number",
      "description": "Fictional monthly price delta."
