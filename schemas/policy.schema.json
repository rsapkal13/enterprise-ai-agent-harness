{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-agent-harness.org/schemas/policy.schema.json",
  "title": "Policy",
  "description": "Defines policy metadata, scope, rules, default decision, approval conditions, and audit obligations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "name",
    "description",
    "owner",
    "lifecycle_state",
    "scope",
    "default_decision",
    "rules"
  ],
  "properties": {
    "id": { "type": "string", "description": "Stable policy identifier." },
    "version": { "type": "string", "description": "Version of this policy definition." },
    "name": { "type": "string", "description": "Human-readable policy name." },
    "description": { "type": "string", "description": "Policy purpose and control intent." },
    "owner": { "type": "string", "description": "Accountable owner or owning group." },
    "lifecycle_state": {
      "type": "string",
      "enum": ["draft", "pending_approval", "approved", "active", "deprecated", "retired", "blocked"]
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "staging", "prod"]
    },
    "scope": {
      "type": "object",
      "description": "Objects and execution points covered by the policy.",
      "additionalProperties": false,
      "properties": {
        "agents": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "string" } },
        "tools": { "type": "array", "items": { "type": "string" } },
        "workflows": { "type": "array", "items": { "type": "string" } },
        "systems": { "type": "array", "items": { "type": "string" } },
        "context_scopes": { "type": "array", "items": { "type": "string" } },
        "enforcement_points": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["agent_request", "skill_invocation", "tool_call", "workflow_step", "context_access", "system_interaction"]
          }
        }
      }
    },
    "applicable_risk_tiers": {
      "type": "array",
      "description": "Risk tiers where this policy applies.",
      "items": {
        "type": "string",
        "enum": ["T0", "T1", "T2", "T3"]
      }
    },
    "default_decision": {
      "type": "string",
      "enum": ["allow", "deny", "require_approval"],
      "description": "Decision when no rule explicitly permits execution."
    },
    "rules": {
      "type": "array",
      "description": "Declarative rules. This is not a runtime expression language.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "condition", "decision"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "condition": {
            "type": "object",
            "description": "Portable condition descriptor.",
            "additionalProperties": true
          },
          "decision": {
            "type": "string",
            "enum": ["allow", "deny", "require_approval"]
          }
        }
      }
    },
    "approval_conditions": {
      "type": "array",
      "description": "Conditions that require human approval.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "audit_obligations": {
      "type": "array",
      "description": "Audit evidence required when this policy is evaluated.",
      "items": { "type": "string" }
    },
    "evaluation_refs": {
      "type": "array",
      "description": "Evaluation IDs that test this policy.",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
