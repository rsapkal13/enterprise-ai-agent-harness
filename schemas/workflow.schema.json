{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-agent-harness.org/schemas/workflow.schema.json",
  "title": "Workflow",
  "description": "Defines controlled multi-step execution with policy checks, tool calls, approvals, retries, compensation, escalation, and completion criteria.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "name",
    "description",
    "owner",
    "lifecycle_state",
    "steps",
    "completion_criteria"
  ],
  "properties": {
    "id": { "type": "string", "description": "Stable workflow identifier." },
    "version": { "type": "string", "description": "Version of this workflow definition." },
    "name": { "type": "string", "description": "Human-readable workflow name." },
    "description": { "type": "string", "description": "Business purpose of the workflow." },
    "owner": { "type": "string", "description": "Accountable owner or owning group." },
    "risk_tier": {
      "type": "string",
      "enum": ["T0", "T1", "T2", "T3"]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["draft", "pending_approval", "approved", "active", "deprecated", "retired", "blocked"]
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "staging", "prod"]
    },
    "steps": {
      "type": "array",
      "description": "Ordered workflow steps.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "name"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["policy", "tool", "approval", "decision", "context", "completion"]
          },
          "name": { "type": "string" },
          "condition": {
            "type": "object",
            "description": "Condition for entering or completing this step.",
            "additionalProperties": true
          },
          "policy_ref": { "type": "string" },
          "tool_ref": { "type": "string" },
          "context_scope_ref": { "type": "string" },
          "ui_manifest_ref": { "type": "string" },
          "approval": {
            "type": "object",
            "description": "Approval requirements for this step.",
            "additionalProperties": true
          },
          "retries": {
            "type": "object",
            "description": "Retry expectations.",
            "additionalProperties": false,
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 0 },
              "strategy": { "type": "string" }
            }
          },
          "compensation": {
            "type": "object",
            "description": "Compensating action guidance.",
            "additionalProperties": true
          },
          "failure_behaviour": {
            "type": "string",
            "enum": ["fail_workflow", "retry", "compensate", "manual_review", "continue"]
          },
          "on_success": { "type": "string" },
          "on_failure": { "type": "string" }
        }
      }
    },
    "escalation_paths": {
      "type": "array",
      "description": "Escalation path references or public-safe role names.",
      "items": { "type": "string" }
    },
    "completion_criteria": {
      "type": "array",
      "description": "Criteria required for successful completion.",
      "items": { "type": "string" }
    },
    "evaluation_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "audit_required": {
      "type": "boolean",
      "description": "Whether workflow execution must emit audit events."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
