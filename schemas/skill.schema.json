{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-agent-harness.org/schemas/skill.schema.json",
  "title": "Skill",
  "description": "Defines a reusable governed business capability that agents may request.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "name",
    "description",
    "owner",
    "risk_tier",
    "lifecycle_state",
    "input_contract",
    "output_contract",
    "tool_bindings",
    "policies"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable skill identifier."
    },
    "version": {
      "type": "string",
      "description": "Version of this skill definition."
    },
    "name": {
      "type": "string",
      "description": "Human-readable skill name."
    },
    "description": {
      "type": "string",
      "description": "Business description of the capability."
    },
    "owner": {
      "type": "string",
      "description": "Accountable owner or owning group."
    },
    "risk_tier": {
      "type": "string",
      "enum": ["T0", "T1", "T2", "T3"],
      "description": "Risk tier for this capability."
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["draft", "pending_approval", "approved", "active", "deprecated", "retired", "blocked"]
    },
    "environment": {
      "type": "string",
      "enum": ["dev", "test", "staging", "prod"]
    },
    "approved_agents": {
      "type": "array",
      "description": "Agent IDs approved to request this skill.",
      "items": { "type": "string" }
    },
    "input_contract": {
      "type": "object",
      "description": "Input contract reference or lightweight field list.",
      "additionalProperties": true
    },
    "output_contract": {
      "type": "object",
      "description": "Output contract reference or lightweight field list.",
      "additionalProperties": true
    },
    "required_context": {
      "type": "array",
      "description": "Context scope IDs required by the skill.",
      "items": { "type": "string" }
    },
    "tool_bindings": {
      "type": "array",
      "description": "Tool IDs this skill may invoke.",
      "items": { "type": "string" }
    },
    "policies": {
      "type": "array",
      "description": "Policy IDs that apply to this skill.",
      "items": { "type": "string" }
    },
    "workflow_ref": {
      "type": "string",
      "description": "Workflow ID used for multi-step execution."
    },
    "evaluation_refs": {
      "type": "array",
      "description": "Evaluation or evaluation pack IDs required for this skill.",
      "items": { "type": "string" }
    },
    "audit_required": {
      "type": "boolean",
      "description": "Whether skill invocation must produce audit evidence."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
