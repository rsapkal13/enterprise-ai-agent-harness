{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-agent-harness.org/schemas/evaluation.schema.json",
  "title": "Evaluation",
  "description": "Defines evaluation packs, scenarios, golden outcomes, trajectory expectations, pass thresholds, risk applicability, and certification status.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "risk_tier": { "type": "string", "enum": ["T0", "T1", "T2", "T3"] },
    "lifecycle_state": { "type": "string", "enum": ["draft", "pending_approval", "approved", "active", "deprecated", "retired", "blocked"] },
    "owner": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["business", "technical"],
          "properties": {
            "business": { "type": "string" },
            "technical": { "type": "string" },
            "risk": { "type": "string" }
          }
        }
      ]
    }
  },
  "required": [
    "id",
    "version",
    "name",
    "description",
    "owner",
    "lifecycle_state",
    "target_type",
    "scenarios",
    "pass_threshold"
  ],
  "properties": {
    "id": { "type": "string", "description": "Stable evaluation or evaluation pack identifier." },
    "version": { "type": "string", "description": "Version of this evaluation definition." },
    "name": { "type": "string", "description": "Human-readable evaluation name." },
    "description": { "type": "string", "description": "Evaluation purpose." },
    "owner": { "$ref": "#/$defs/owner" },
    "lifecycle_state": { "$ref": "#/$defs/lifecycle_state" },
    "target_type": {
      "type": "string",
      "enum": ["agent", "skill", "policy", "tool", "workflow", "system", "journey"],
      "description": "Object type being evaluated."
    },
    "target_refs": {
      "type": "array",
      "description": "Object IDs this evaluation applies to.",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "applicable_risk_tiers": {
      "type": "array",
      "description": "Risk tiers where this evaluation is expected.",
      "items": { "$ref": "#/$defs/risk_tier" },
      "uniqueItems": true
    },
    "scenarios": {
      "type": "array",
      "description": "Evaluation scenarios.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "description": "Stable scenario identifier within the evaluation." },
          "description": { "type": "string", "description": "Scenario intent." },
          "inputs_ref": { "type": "string", "description": "Reference to scenario inputs or fixture data." },
          "golden_outcome": {
            "type": "object",
            "description": "Expected outcome or assertion summary.",
            "additionalProperties": true
          },
          "trajectory_expectations": {
            "type": "array",
            "description": "Expected tool, policy, workflow, approval, or audit path assertions.",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "adversarial": { "type": "boolean", "description": "Whether this scenario tests adversarial or boundary behaviour." }
        }
      }
    },
    "pass_threshold": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Minimum passing score from 0 to 1."
    },
    "certification_status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "passed", "failed", "expired", "waived"],
      "description": "Certification status for this evaluation."
    },
    "audit_refs": {
      "type": "array",
      "description": "Audit event IDs associated with this evaluation or certification evidence.",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
  }
}
