{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-agent-harness.org/schemas/tool.schema.json",
  "title": "Tool",
  "description": "A governed wrapper around an external action, lookup, or integration.",
  "type": "object",
  "required": ["id", "version", "status", "name", "description", "adapter", "riskLevel", "systemId"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable tool identifier."
    },
    "version": {
      "type": "string",
      "description": "Specification version of this tool definition."
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "retired"],
      "description": "Lifecycle status for this tool."
    },
    "name": {
      "type": "string",
      "description": "Human-readable tool name."
    },
    "description": {
      "type": "string",
      "description": "Business-safe description of the tool."
    },
    "adapter": {
      "type": "string",
      "enum": ["rest", "mcp", "mock", "workflow", "data"],
      "description": "Adapter category used to execute the tool."
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "restricted"]
    },
    "systemId": {
      "type": "string",
      "description": "Registered system this tool interacts with."
    },
    "sideEffect": {
      "type": "string",
      "enum": ["read", "write", "workflow", "external_notification"],
      "description": "Side-effect category of the tool call."
    },
    "dataClassification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"],
      "description": "Highest expected data classification handled by this tool."
    },
    "inputSchema": {
      "type": "string",
      "description": "Optional schema reference for tool input."
    },
    "outputSchema": {
      "type": "string",
      "description": "Optional schema reference for tool output."
    },
    "auditRequired": {
      "type": "boolean",
      "description": "Whether tool calls must be written to the audit log."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Search and classification tags."
    }
  }
}
