{
  "name": "enterprise-ai-agent-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Specification and validation tooling for Enterprise AI Agent Harness.",
  "type": "module",
  "scripts": {
    "validate:schemas": "node scripts/validate-schemas.js",
    "validate:examples": "node scripts/validate-examples.js",
    "validate:references": "node scripts/validate-references.js",
    "validate": "npm run validate:schemas && npm run validate:examples && npm run validate:references",
    "test": "node --test 'packages/*/tests/*.test.js'",
    "demo:telco": "node apps/demo-runner/src/telco-demo.js",
    "admin:dev": "npm --prefix apps/admin-console run dev",
    "admin:build": "npm --prefix apps/admin-console run build",
    "admin:preview": "npm --prefix apps/admin-console run preview"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.6.1"
  }
}
